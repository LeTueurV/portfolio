# Configuration pour production sur Render ou autre plateforme avec HTTPS

APP_NAME=Portfolio
APP_ENV=production
APP_DEBUG=true
# Utilisez votre domaine Render ou personnalisé
APP_URL=https://portfolio-mlb3.onrender.com/

# Database - utilisez votre Supabase ou autre
DB_CONNECTION=pgsql
DB_HOST=votre-host.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=votre-username
DB_PASSWORD=votre-password

# Cache et session
CACHE_DRIVER=database
SESSION_DRIVER=database

# Mail (optionnel)
MAIL_DRIVER=log

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Sentry ou autre monitoring (optionnel)
# SENTRY_LARAVEL_DSN=
